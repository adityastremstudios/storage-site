# --- Database ---
DATABASE_URL=postgresql://uetms:uetms@localhost:5432/uetms

# --- Redis (optional; falls back to in-memory cache if unset/unreachable) ---
REDIS_URL=redis://localhost:6379

# --- Server ---
PORT=4000
CORS_ORIGIN=*
NODE_ENV=development

# --- Auth ---
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# --- Seed (creates admin + demo tournament with 16 teams & 3 published matches) ---
SEED=true
ADMIN_EMAIL=admin@uetms.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123
