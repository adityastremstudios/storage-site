generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TOURNAMENT_MANAGER
  OBSERVER
  DATA_ENTRY
  CASTER
  READ_ONLY
}

enum TournamentStatus {
  DRAFT
  UPCOMING
  LIVE
  COMPLETED
  ARCHIVED
}

enum MatchStatus {
  DRAFT
  SCHEDULED
  LIVE
  COMPLETED
  PUBLISHED
  LOCKED
}

// NEW — discriminates scoring/stat strategy per game. "br" keeps every existing
// code path untouched; "h2h" is the hook for Valorant/CS2 later.
enum GameFormat {
  BR
  H2H
}

enum StatSource {
  IMPORT
  MANUAL
  DERIVED
}

enum RecalcStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  username     String        @unique
  passwordHash String
  role         Role          @default(READ_ONLY)
  isActive     Boolean       @default(true)
  tokenVersion Int           @default(0)
  lastLoginAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  activityLogs ActivityLog[]
  auditLogs    AuditLog[]
  tournaments  Tournament[]
  media        Media[]
  notifications Notification[]
  matchVersions MatchVersion[]
  penalties     Penalty[]
  recalcJobs    RecalcJob[]

  @@map("users")
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  ip        String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("activity_logs")
}

model Game {
  id            Int           @id @default(autoincrement())
  name          String        @unique
  slug          String        @unique
  shortName     String?
  logoUrl       String?
  statTemplate  Json?
  overlayConfig Json?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  // NEW
  format        GameFormat    @default(BR)
  tournaments   Tournament[]
  maps          GameMap[]
  connectors    ApiConnector[]
  pointRules    PointRule[]
  statDefs      StatDefinition[]
  achievements  AchievementDef[]

  @@map("games")
}

// NEW — the multi-game hook. Declares which stats a game has, how they
// aggregate and how they display. BR rows are seeded to match today's columns,
// so nothing changes now; Valorant/CS2 plug in by adding rows, not code.
model StatDefinition {
  id          Int     @id @default(autoincrement())
  gameId      Int
  game        Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  key         String
  label       String
  scope       String  @default("player") // player | team
  unit        String?
  aggregation String  @default("sum")    // sum | avg | max | min | last
  category    String?
  isDerived   Boolean @default(false)
  formula     String?
  decimals    Int     @default(0)
  order       Int     @default(0)
  isVisible   Boolean @default(true)

  @@unique([gameId, scope, key])
  @@map("stat_definitions")
}

model GameMap {
  id       Int     @id @default(autoincrement())
  gameId   Int
  game     Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  name     String
  imageUrl String?
  matches  Match[]

  @@unique([gameId, name])
  @@map("maps")
}

model PointRule {
  id              Int          @id @default(autoincrement())
  gameId          Int?
  game            Game?        @relation(fields: [gameId], references: [id], onDelete: SetNull)
  name            String
  placementPoints Json
  killPoint       Float        @default(1)
  isDefault       Boolean      @default(false)
  // NEW — ordered tiebreaker chain, e.g. ["points","wwcd","placementPoints","kills","lastPlacement"]
  tiebreakers     Json?
  tournaments     Tournament[]

  @@map("point_rules")
}

model Organization {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  logoUrl String?
  country String?
  teams   Team[]

  @@map("organizations")
}

model Tournament {
  id             Int              @id @default(autoincrement())
  name           String
  slug           String           @unique
  gameId         Int
  game           Game             @relation(fields: [gameId], references: [id])
  logoUrl        String?
  bannerUrl      String?
  organizer      String?
  country        String?
  timezone       String           @default("Asia/Kolkata")
  status         TournamentStatus @default(DRAFT)
  pointRuleId    Int?
  pointRule      PointRule?       @relation(fields: [pointRuleId], references: [id], onDelete: SetNull)
  pointsOverride Json?
  prizePool      String?
  startDate      DateTime?
  endDate        DateTime?
  isArchived     Boolean          @default(false)
  deletedAt      DateTime?
  createdById    Int?
  createdBy      User?            @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  rounds         Round[]
  matches        Match[]
  entries        TournamentTeam[]
  standings      OverallStanding[]
  sponsors       Sponsor[]
  broadcastProfiles BroadcastProfile[]
  overlayOutputs OverlayOutput[]
  feeds          FeedSource[]
  penalties      Penalty[]
  records        RecordEntry[]
  playerAggregates PlayerAggregate[]
  teamAggregates   TeamAggregate[]
  playerAchievements PlayerAchievement[]
  recalcJobs     RecalcJob[]

  @@map("tournaments")
}

model Round {
  id           Int        @id @default(autoincrement())
  tournamentId Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name         String
  order        Int        @default(0)
  isLocked     Boolean    @default(false)
  isPublished  Boolean    @default(false)
  startDate    DateTime?
  // NEW — stage grouping (Qualifier / Group Stage / Semis / Finals)
  stage        String?
  groupName    String?
  matches      Match[]
  feeds        FeedSource[]

  @@unique([tournamentId, name])
  @@map("rounds")
}

model Team {
  id             Int              @id @default(autoincrement())
  name           String           @unique
  slug           String           @unique
  shortName      String?
  logoUrl        String?
  country        String?
  organizationId Int?
  organization   Organization?    @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  isActive       Boolean          @default(true)
  deletedAt      DateTime?
  createdAt      DateTime         @default(now())
  // NEW
  coach          String?
  memberships    TeamPlayer[]
  currentPlayers Player[]         @relation("CurrentTeam")
  teamStats      TeamStat[]
  playerStats    PlayerStat[]
  entries        TournamentTeam[]
  standings      OverallStanding[]
  wonMatches     Match[]          @relation("MatchWinner")
  penalties      Penalty[]
  aggregates     TeamAggregate[]
  records        RecordEntry[]

  @@map("teams")
}

model TournamentTeam {
  id           Int        @id @default(autoincrement())
  tournamentId Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamId       Int
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  seed         Int?
  groupName    String?
  // NEW
  slotNumber   Int?

  @@unique([tournamentId, teamId])
  @@map("tournament_teams")
}

model Player {
  id            Int          @id @default(autoincrement())
  // CHANGED: global @unique removed. Two real people can share an IGN; the old
  // constraint silently merged them into one player and corrupted their stats.
  // Identity now resolves by externalId -> team roster -> unambiguous IGN.
  ign           String
  realName      String?
  photoUrl      String?
  country       String?
  role          String?
  currentTeamId Int?
  currentTeam   Team?        @relation("CurrentTeam", fields: [currentTeamId], references: [id], onDelete: SetNull)
  deletedAt     DateTime?
  createdAt     DateTime     @default(now())
  // NEW — stable identity when the game API supplies a UID, plus known aliases
  externalId    String?      @unique
  aliases       String[]     @default([])
  memberships   TeamPlayer[]
  stats         PlayerStat[]
  aggregates    PlayerAggregate[]
  achievements  PlayerAchievement[]
  records       RecordEntry[]

  @@index([ign])
  @@map("players")
}

model TeamPlayer {
  id       Int       @id @default(autoincrement())
  teamId   Int
  team     Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId Int
  player   Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  joinedAt DateTime  @default(now())
  leftAt   DateTime?
  isActive Boolean   @default(true)
  // NEW
  isSubstitute Boolean @default(false)

  @@index([teamId, isActive])
  @@index([playerId])
  @@map("team_players")
}

model Match {
  id              Int         @id @default(autoincrement())
  tournamentId    Int
  tournament      Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  roundId         Int
  round           Round       @relation(fields: [roundId], references: [id], onDelete: Cascade)
  mapId           Int?
  map             GameMap?    @relation(fields: [mapId], references: [id], onDelete: SetNull)
  matchNumber     Int
  scheduledAt     DateTime?
  startedAt       DateTime?
  endedAt         DateTime?
  status          MatchStatus @default(DRAFT)
  winnerTeamId    Int?
  winnerTeam      Team?       @relation("MatchWinner", fields: [winnerTeamId], references: [id], onDelete: SetNull)
  // CHANGED: was globally @unique, which let one tournament overwrite another
  // tournament's match when both feeds used the same matchId. Now scoped below.
  externalMatchId String?
  rawJson         Json?
  isLocked        Boolean     @default(false)
  deletedAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  // NEW
  notes           String?
  tags            String[]    @default([])
  manualLock      Boolean     @default(false)
  archivedAt      DateTime?
  publishedAt     DateTime?
  statusBefore    MatchStatus?
  importCount     Int         @default(0)
  lastImportAt    DateTime?
  currentVersion  Int         @default(0)
  clonedFromId    Int?
  teamStats       TeamStat[]
  playerStats     PlayerStat[]
  versions        MatchVersion[]
  penalties       Penalty[]
  records         RecordEntry[]
  playerAchievements PlayerAchievement[]

  @@unique([tournamentId, externalMatchId])
  @@index([tournamentId, roundId])
  @@index([roundId, matchNumber])
  @@map("matches")
}

// NEW — every import/edit snapshots here. Powers Restore, Compare and Import History.
model MatchVersion {
  id           Int        @id @default(autoincrement())
  matchId      Int
  match        Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  version      Int
  hash         String
  source       String     @default("import") // import | feed | manual | recalc
  rawPayload   Json?
  mappedTeams  Json?
  statsBefore  Json?
  note         String?
  actorId      Int?
  actor        User?      @relation(fields: [actorId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())

  @@unique([matchId, version])
  @@index([matchId, createdAt])
  @@map("match_versions")
}

// NEW — point deductions (teamkill, late, DC, cheating). Applied at recalc.
model Penalty {
  id           Int        @id @default(autoincrement())
  tournamentId Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matchId      Int?
  match        Match?     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  teamId       Int
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  points       Float
  reason       String
  createdById  Int?
  createdBy    User?      @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())

  @@index([tournamentId, teamId])
  @@map("penalties")
}

model TeamStat {
  id              Int     @id @default(autoincrement())
  matchId         Int
  match           Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  teamId          Int
  team            Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  placement       Int
  kills           Int     @default(0)
  damage          Float   @default(0)
  placementPoints Float   @default(0)
  killPoints      Float   @default(0)
  totalPoints     Float   @default(0)
  isWWCD          Boolean @default(false)
  // NEW — manual override support (AUTO FIRST / MANUAL ALWAYS)
  source          StatSource @default(IMPORT)
  overrides       Json?
  // NEW — which stat keys the source actually supplied. Keys absent from this
  // list are treated as "no data" (shown as —, excluded from averages/records)
  // instead of a real zero.
  provided        String[]   @default([])
  // NEW — optional stats, null when the source does not supply them
  survivalTime    Float?
  damageTaken     Float?
  penaltyPoints   Float      @default(0)
  adjustedPoints  Float?

  @@unique([matchId, teamId])
  @@index([teamId])
  @@map("team_stats")
}

model PlayerStat {
  id           Int     @id @default(autoincrement())
  matchId      Int
  match        Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId     Int
  player       Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  teamId       Int?
  team         Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)
  kills        Int     @default(0)
  damage       Float   @default(0)
  assists      Int     @default(0)
  knocks       Int     @default(0)
  revives      Int     @default(0)
  headshots    Int     @default(0)
  survivalTime Float?
  isMvp        Boolean @default(false)
  mvpScore     Float   @default(0)
  // NEW — manual override support
  source       StatSource @default(IMPORT)
  overrides    Json?
  provided     String[]   @default([])
  // NEW — extended stats, all nullable so "not supplied" stays distinct from 0
  deaths       Int?
  knockedDown  Int?
  longestKill  Float?
  distance     Float?
  heals        Int?
  boosts       Int?
  selfDamage   Float?
  teamDamage   Float?
  firstBlood   Boolean @default(false)
  clutches     Int?
  rating       Float?

  @@unique([matchId, playerId])
  @@index([playerId])
  @@index([teamId])
  @@map("player_stats")
}

model OverallStanding {
  id              Int        @id @default(autoincrement())
  tournamentId    Int
  tournament      Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  scope           String     @default("overall")
  teamId          Int
  team            Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  matchesPlayed   Int        @default(0)
  totalKills      Int        @default(0)
  placementPoints Float      @default(0)
  killPoints      Float      @default(0)
  totalPoints     Float      @default(0)
  wwcd            Int        @default(0)
  avgPlacement    Float      @default(0)
  lastPlacement   Int?
  rank            Int        @default(0)
  updatedAt       DateTime   @updatedAt
  // NEW
  penaltyPoints   Float      @default(0)
  tiebreakReason  String?

  @@unique([tournamentId, scope, teamId])
  @@map("overall_standings")
}

// NEW — materialised player stats. Rebuilt by the recalculation engine so
// profile/comparison pages never scan every match row.
model PlayerAggregate {
  id            Int        @id @default(autoincrement())
  scope         String     @default("career") // career | tournament:<id> | round:<id> | map:<name>
  playerId      Int
  player        Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  tournamentId  Int?
  tournament    Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamId        Int?
  matches       Int        @default(0)
  kills         Int        @default(0)
  damage        Float      @default(0)
  assists       Int        @default(0)
  knocks        Int        @default(0)
  revives       Int        @default(0)
  headshots     Int        @default(0)
  deaths        Int?
  survivalTime  Float?
  mvpCount      Int        @default(0)
  wwcdCount     Int        @default(0)
  avgKills      Float      @default(0)
  avgDamage     Float?
  avgPlacement  Float      @default(0)
  avgSurvival   Float?
  bestMatchId   Int?
  worstMatchId  Int?
  rating        Float?
  provided      String[]   @default([])
  stale         Boolean    @default(true)
  updatedAt     DateTime   @updatedAt

  @@unique([scope, playerId])
  @@index([tournamentId])
  @@map("player_aggregates")
}

// NEW — materialised team stats, same contract as PlayerAggregate.
model TeamAggregate {
  id            Int        @id @default(autoincrement())
  scope         String     @default("career")
  teamId        Int
  team          Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tournamentId  Int?
  tournament    Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matches       Int        @default(0)
  points        Float      @default(0)
  kills         Int        @default(0)
  damage        Float      @default(0)
  wwcd          Int        @default(0)
  avgPlacement  Float      @default(0)
  avgKills      Float      @default(0)
  avgDamage     Float?
  avgSurvival   Float?
  bestMatchId   Int?
  worstMatchId  Int?
  provided      String[]   @default([])
  stale         Boolean    @default(true)
  updatedAt     DateTime   @updatedAt

  @@unique([scope, teamId])
  @@index([tournamentId])
  @@map("team_aggregates")
}

// NEW — tournament + all-time records (highest kills, longest survival, ...).
model RecordEntry {
  id           Int         @id @default(autoincrement())
  scope        String      @default("alltime") // alltime | tournament:<id>
  tournamentId Int?
  tournament   Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  key          String
  label        String
  value        Float
  displayValue String?
  playerId     Int?
  player       Player?     @relation(fields: [playerId], references: [id], onDelete: SetNull)
  teamId       Int?
  team         Team?       @relation(fields: [teamId], references: [id], onDelete: SetNull)
  matchId      Int?
  match        Match?      @relation(fields: [matchId], references: [id], onDelete: SetNull)
  meta         Json?
  updatedAt    DateTime    @updatedAt

  @@unique([scope, key])
  @@map("record_entries")
}

// NEW — achievement rules are data, not code, so thresholds stay editable.
model AchievementDef {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  description String?
  iconUrl     String?
  tier        String?
  gameId      Int?
  game        Game?    @relation(fields: [gameId], references: [id], onDelete: SetNull)
  rule        Json
  isActive    Boolean  @default(true)
  unlocks     PlayerAchievement[]

  @@map("achievement_defs")
}

model PlayerAchievement {
  id            Int            @id @default(autoincrement())
  playerId      Int
  player        Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)
  achievementId Int
  achievement   AchievementDef @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  tournamentId  Int?
  tournament    Tournament?    @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matchId       Int?
  match         Match?         @relation(fields: [matchId], references: [id], onDelete: SetNull)
  value         Float?
  unlockedAt    DateTime       @default(now())

  @@unique([playerId, achievementId, tournamentId])
  @@index([tournamentId])
  @@map("player_achievements")
}

// NEW — serialises recalculation so two concurrent feed polls cannot
// interleave and write stale standings.
model RecalcJob {
  id           Int          @id @default(autoincrement())
  tournamentId Int
  tournament   Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  scope        String
  status       RecalcStatus @default(QUEUED)
  requestedById Int?
  requestedBy  User?        @relation(fields: [requestedById], references: [id], onDelete: SetNull)
  error        String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime     @default(now())

  @@index([tournamentId, status])
  @@map("recalc_jobs")
}

model ApiConnector {
  id         Int       @id @default(autoincrement())
  gameId     Int?
  game       Game?     @relation(fields: [gameId], references: [id], onDelete: SetNull)
  name       String
  type       String    @default("push")
  // DEPRECATED: plaintext key. Kept so the migration can read and hash existing
  // keys, then null them out. Never returned by the API any more.
  apiKey     String    @unique
  // NEW — hashed key + display prefix
  apiKeyHash String?   @unique
  apiKeyPrefix String?
  // NEW — a connector may only import into these tournaments (empty = all)
  tournamentIds Int[]  @default([])
  config     Json?
  isActive   Boolean   @default(true)
  imports    Int       @default(0)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@map("api_connectors")
}

model FeedSource {
  id             Int         @id @default(autoincrement())
  name           String
  url            String
  adapter        String      @default("auto")
  method         String      @default("GET")
  headers        Json?
  tournamentId   Int
  tournament     Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  roundId        Int?
  round          Round?      @relation(fields: [roundId], references: [id], onDelete: SetNull)
  roundName      String?
  mapName        String?
  intervalSec    Int         @default(20)
  isActive       Boolean     @default(false)
  autoPublish    Boolean     @default(true)
  importWhen     String      @default("finished")
  killField      String      @default("auto")
  minTeams       Int         @default(2)
  lastHash       String?
  lastMatchKey   String?
  lastStatus     String?
  lastMessage    String?
  lastRunAt      DateTime?
  lastImportAt   DateTime?
  imports        Int         @default(0)
  errors         Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  // NEW — stable match key for feeds that send no matchId, so live polling
  // updates one match instead of creating a new one on every tick.
  sessionKey     String?
  sessionStartedAt DateTime?
  logs           FeedLog[]

  @@map("feed_sources")
}

model FeedLog {
  id        Int        @id @default(autoincrement())
  feedId    Int
  feed      FeedSource @relation(fields: [feedId], references: [id], onDelete: Cascade)
  status    String
  message   String?
  matchKey  String?
  matchId   Int?
  teams     Int?
  ms        Int?
  createdAt DateTime   @default(now())

  @@index([feedId, createdAt])
  @@map("feed_logs")
}

model OverlayTemplate {
  id     Int     @id @default(autoincrement())
  name   String
  type   String
  gameId Int?
  html   String?
  config Json?

  @@map("overlay_templates")
}

model OverlayOutput {
  id           Int        @id @default(autoincrement())
  tournamentId Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  type         String
  data         Json
  publishedAt  DateTime   @default(now())

  @@index([tournamentId, type, publishedAt])
  @@map("overlay_outputs")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  entity    String
  entityId  Int
  action    String
  before    Json?
  after     Json?
  createdAt DateTime @default(now())
  // NEW — mandatory reason on manual overrides, plus request origin
  reason    String?
  ip        String?

  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id        Int       @id @default(autoincrement())
  userId    Int?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String?
  type      String    @default("info")
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("notifications")
}

model Media {
  id           Int      @id @default(autoincrement())
  url          String
  key          String?
  type         String?
  size         Int?
  uploadedById Int?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@map("media")
}

model Sponsor {
  id           Int        @id @default(autoincrement())
  tournamentId Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name         String
  logoUrl      String?
  tier         String?
  order        Int        @default(0)

  @@map("sponsors")
}

model BroadcastProfile {
  id           Int        @id @default(autoincrement())
  tournamentId Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name         String
  config       Json?
  createdAt    DateTime   @default(now())

  @@map("broadcast_profiles")
}

model Setting {
  key   String @id
  value Json

  @@map("settings")
}

model Backup {
  id        Int      @id @default(autoincrement())
  filename  String
  size      Int?
  createdAt DateTime @default(now())

  @@map("backups")
}
